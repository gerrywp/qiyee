{{define "content"}}
<div class="wrapper">
  <div class="content-wrapper">
    <section class="content">
      <div class="container-fluid">
        <div class="row">
          <div class="col-12">
            <h3 class="mb-3">Banner管理</h3>
          </div>
        </div>

        <!-- Banner展示区域 -->
        <div class="row" id="bannerContainer">
          {{if .banner1}}
          <div class="col-md-4 mb-3">
            <div class="card card-widget">
              <div class="card-header bg-primary">
                <h5>Banner 1</h5>
              </div>
              <div class="card-body p-0">
                <div
                  class="banner-preview-wrapper"
                  style="width: 100%; height: 225px; overflow: hidden; background-color: #f5f5f5"
                >
                  <img
                    id="preview1"
                    class="img-fluid"
                    src="{{.banner1.ThumbUrl}}"
                    style="width: 100%; height: 100%; object-fit: cover"
                    alt="Banner 1"
                  />
                </div>
              </div>
              <div class="card-footer">
                <button type="button" class="btn btn-primary btn-sm" onclick="initUpload(1)">
                  上传图片
                </button>
                <button type="button" class="btn btn-info btn-sm" onclick="showCropper(1)">
                  预览原图
                </button>
              </div>
            </div>
          </div>
          {{ end }}

          {{if .banner2}}
          <div class="col-md-4 mb-3">
            <div class="card card-widget">
              <div class="card-header bg-success">
                <h5>Banner 2</h5>
              </div>
              <div class="card-body p-0">
                <div
                  class="banner-preview-wrapper"
                  style="width: 100%; height: 225px; overflow: hidden; background-color: #f5f5f5"
                >
                  <img
                    id="preview2"
                    class="img-fluid"
                    src="{{.banner2.ThumbUrl}}"
                    style="width: 100%; height: 100%; object-fit: cover"
                    alt="Banner 2"
                  />
                </div>
              </div>
              <div class="card-footer">
                <button type="button" class="btn btn-primary btn-sm" onclick="initUpload(2)">
                  上传图片
                </button>
                <button type="button" class="btn btn-info btn-sm" onclick="showCropper(2)">
                  预览原图
                </button>
              </div>
            </div>
          </div>
          {{ end }}

          {{if .banner3}}
          <div class="col-md-4 mb-3">
            <div class="card card-widget">
              <div class="card-header bg-danger">
                <h5>Banner 3</h5>
              </div>
              <div class="card-body p-0">
                <div
                  class="banner-preview-wrapper"
                  style="width: 100%; height: 225px; overflow: hidden; background-color: #f5f5f5"
                >
                  <img
                    id="preview3"
                    class="img-fluid"
                    src="{{.banner3.ThumbUrl}}"
                    style="width: 100%; height: 100%; object-fit: cover"
                    alt="Banner 3"
                  />
                </div>
              </div>
              <div class="card-footer">
                <button type="button" class="btn btn-primary btn-sm" onclick="initUpload(3)">
                  上传图片
                </button>
                <button type="button" class="btn btn-info btn-sm" onclick="showCropper(3)">
                  预览原图
                </button>
              </div>
            </div>
          </div>
          {{ end }}
        </div>
      </div>
    </section>
  </div>
</div>

<!-- 上传文件的隐藏input -->
<input id="fileInput" type="file" accept="image/jpeg,image/gif,image/png" style="display: none" />

<!-- 原图预览Modal -->
<div
  class="modal fade"
  id="previewModal"
  tabindex="-1"
  role="dialog"
  aria-labelledby="previewModalLabel"
  aria-hidden="true"
  style="padding: 0 !important"
>
  <div
    class="modal-dialog"
    role="document"
    style="max-width: 100%; width: 100vw; height: 100vh; margin: 0"
  >
    <div class="modal-content" style="height: 100vh; display: flex; flex-direction: column">
      <div
        class="modal-header bg-info text-white"
        style="padding-top: 5px; padding-bottom: 5px; flex-shrink: 0"
      >
        <h6 class="modal-title">原始图片预览</h6>
        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div
        class="modal-body text-center"
        style="
          overflow: auto;
          flex: 1;
          display: flex;
          align-items: center;
          justify-content: center;
          background-color: #f5f5f5;
          padding: 0;
        "
      >
        <img
          id="previewImage"
          src=""
          style="max-width: 100%; max-height: 100%; width: auto; height: auto"
          alt="Preview"
        />
      </div>
    </div>
  </div>
</div>
{{ end }}

{{define "script"}}
<script>
  let currentBannerId = null

  // 初始化上传
  function initUpload(bannerId) {
    currentBannerId = bannerId
    // 清空文件输入框，确保每次都能触发change事件
    $('#fileInput').val('')
    $('#fileInput').click()
  }

  // 文件选择处理
  $('#fileInput').on('change', function (e) {
    const file = e.target.files[0]
    if (!file) return

    // 验证文件类型
    if (!file.type.startsWith('image/')) {
      toastr.error('请选择图片文件')
      return
    }

    uploadOriginalImage(file)
  })

  $('#previewModal').on('show.bs.modal', function () {
    $(this).css('padding-right', '0 !important')
  })

  // 上传原始图片
  function uploadOriginalImage(file) {
    const formData = new FormData()
    formData.append('id', currentBannerId)
    formData.append('file', file)

    $.ajax({
      url: '/pai/banner/upload',
      type: 'POST',
      data: formData,
      processData: false,
      contentType: false,
      success: function (response) {
        if (response.code === 1) {
          toastr.success('✓ 上传成功！')
          setTimeout(() => {
            refreshBannerThumb(currentBannerId)
          }, 300)
        } else {
          toastr.error(response.msg || '上传失败')
        }
      },
      error: function () {
        toastr.error('上传失败，请重试')
      }
    })
  }

  // 刷新单个Banner的缩略图
  function refreshBannerThumb(bannerId) {
    $.ajax({
      url: '/pai/banner',
      type: 'GET',
      dataType: 'html',
      success: function (html) {
        // 从返回的HTML中提取对应Banner的缩略图URL
        const tempDiv = $('<div>').html(html)
        const newThumbUrl = tempDiv.find(`#preview${bannerId}`).attr('src')
        if (newThumbUrl) {
          $(`#preview${bannerId}`).attr('src', newThumbUrl + '?t=' + new Date().getTime())
        }
      }
    })
  }

  // 显示原图预览
  function showCropper(bannerId) {
    currentBannerId = bannerId
    const thumbUrl = $(`#preview${bannerId}`).attr('src')

    // 从缩略图URL推断原始图片URL
    const originImageUrl = thumbUrl.replace('_thumb', '')

    $('#previewImage').attr('src', originImageUrl)
    $('#previewModal').modal('show')
  }

  // 页面加载完成时初始化
  $(function () {
    // 初始化完成
  })
</script>
{{ end }}
