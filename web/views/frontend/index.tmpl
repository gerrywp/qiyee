{{define "content"}}
<section class="hero-section">
  {{with index .Banners 0}}
  <div class="hero-bg" style="background-image:url('{{.Url}}');"></div>
  {{ end }}
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="container h-100">
      <div class="row h-100 align-items-center">
        <div class="col-lg-7">
          <h1 class="display-4 font-weight-bold">欢迎访问企业门户网站</h1>
          <p class="lead mt-3 text-white">我们致力于提供优质的产品和服务，满足您的各种需求。</p>
          <a href="/products" class="btn btn-primary btn-lg mt-4">查看产品</a>
          <a href="/contact" class="btn btn-outline-light btn-lg mt-4 ml-3">联系我们</a>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="container">
  <!-- 产品展示 -->
  <section class="py-5">
    <h2 class="section-title">产品中心</h2>
    <div class="row">
      {{ range.Products }}
      <div class="col-md-4 mb-4">
        <div class="card h-100">
          <img src="{{.ImgUrl}}" class="card-img-top" alt="{{.Name}}" />
          <div class="card-body">
            <h5 class="card-title">{{.Name}}</h5>
            <p class="card-text">{{.Desc}}</p>
            <a href="/products/{{.ID}}" class="btn btn-primary">查看详情</a>
          </div>
        </div>
      </div>
      {{ end }}
    </div>
    <div class="text-center mt-4">
      <a href="/products" class="btn btn-outline-primary">查看全部产品</a>
    </div>
  </section>

  <!-- 关于我们 -->
  <section class="py-5 bg-light">
    <div class="container">
      <h2 class="section-title">关于我们</h2>
      <div class="row align-items-center">
        <div class="col-md-12 mb-4 mb-md-0">
          <p class="mt-3">{{.About.Content | safe}}</p>
          <a href="/about" class="btn btn-primary mt-3">了解更多</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 新闻动态 -->
  <section class="py-5">
    <h2 class="section-title">新闻动态</h2>
    <div class="news-list">
      {{ range.News }}
      <article class="news-item mb-4 p-4 border rounded bg-white">
        <div class="d-flex justify-content-between align-items-start mb-2">
          <h5 class="mb-1">
            <a href="/news/{{.ID}}">{{.Title}}</a>
          </h5>
          <small class="text-muted">{{.CreatedAt.Format "2006-01-02"}}</small>
        </div>
        <a href="/news/{{.ID}}" class="btn btn-sm btn-outline-primary">阅读更多</a>
      </article>
      {{else}}
      <p class="text-muted">暂无新闻内容。</p>
      {{ end }}
    </div>
    <div class="text-center mt-4">
      <a href="/news" class="btn btn-outline-primary">查看全部新闻</a>
    </div>
  </section>
</div>
{{ end }}
