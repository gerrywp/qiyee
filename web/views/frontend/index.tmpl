{{define "content"}}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}}</title>
</head>
<body>

    <!-- 页面内容 -->
    <div class="container">
        <!-- 英雄区域 -->
        <section class="hero-section">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <h1 class="display-4 font-weight-bold">欢迎访问企业门户网站</h1>
                        <p class="lead mt-3">我们致力于提供优质的产品和服务，满足您的各种需求</p>
                        <a href="/products" class="btn btn-primary btn-lg mt-4">查看产品</a>
                        <a href="/contact" class="btn btn-outline-primary btn-lg mt-4 ml-2">联系我们</a>
                    </div>
                    <div class="col-md-6">
                        <img src="/static/upload/1705236728.jpg" alt="企业宣传图" class="img-fluid rounded">
                    </div>
                </div>
            </div>
        </section>

        <!-- 产品展示 -->
        <section class="py-5">
            <h2 class="section-title">产品中心</h2>
            <div class="row">
                {{range .Products}}
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <img src="{{.ImgUrl}}" class="card-img-top" alt="{{.Name}}">
                        <div class="card-body">
                            <h5 class="card-title">{{.Name}}</h5>
                            <p class="card-text">{{.Desc}}</p>
                            <a href="/products/{{.ID}}" class="btn btn-primary">查看详情</a>
                        </div>
                    </div>
                </div>
                {{end}}
            </div>
            <div class="text-center mt-4">
                <a href="/products" class="btn btn-outline-primary">查看全部产品</a>
            </div>
        </section>

        <!-- 关于我们 -->
        <section class="py-5 bg-light">
            <div class="container">
                <h2 class="section-title">关于我们</h2>
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <img src="/static/upload/1705236790.jpg" alt="公司介绍" class="img-fluid rounded">
                    </div>
                    <div class="col-md-6">
                    <p class="mt-3">{{.About.Content | safe}}</p>
                        <a href="/about" class="btn btn-primary mt-3">了解更多</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- 新闻动态 -->
        <section class="py-5">
            <h2 class="section-title">新闻动态</h2>
            <div class="row">
                {{range .News}}
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">{{.Title}}</h5>
                            <p class="card-text">{{.Content}}</p>
                            <p class="card-text"><small class="text-muted">{{.CreateTime}}</small></p>
                            <a href="/news/{{.ID}}" class="btn btn-primary">阅读更多</a>
                        </div>
                    </div>
                </div>
                {{end}}
            </div>
            <div class="text-center mt-4">
                <a href="/news" class="btn btn-outline-primary">查看全部新闻</a>
            </div>
        </section>
    </div>
</body>
</html>
{{end}}