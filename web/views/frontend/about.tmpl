{{define "content"}}
<!-- 关于我们页面内容 -->
<div class="container">
  <!-- 公司介绍 -->
  <section class="py-5">
    <div class="container">
      <div class="about-content">
        <h2 class="section-title">关于我们</h2>
        <div class="row">
          <div class="col-md-12">
            <div class="about-text">
              {{.About.Content | safe}}
            </div>
          </div>
        </div>

        <!-- 团队介绍 -->
        <div class="team-section mt-5">
          <h3 class="text-center mb-4">我们的团队</h3>
          <div class="row">
            <div class="col-md-3 team-member text-center">
              <img
                src="/static/dist/img/user1-128x128.jpg"
                alt="团队成员"
                class="img-fluid rounded-circle mb-3"
                style="max-width: 120px"
              />
              <h5>张三</h5>
              <p class="text-muted">CEO / 创始人</p>
            </div>
            <div class="col-md-3 team-member text-center">
              <img
                src="/static/dist/img/user2-160x160.jpg"
                alt="团队成员"
                class="img-fluid rounded-circle mb-3"
                style="max-width: 120px"
              />
              <h5>李四</h5>
              <p class="text-muted">CTO / 技术总监</p>
            </div>
            <div class="col-md-3 team-member text-center">
              <img
                src="/static/dist/img/user3-128x128.jpg"
                alt="团队成员"
                class="img-fluid rounded-circle mb-3"
                style="max-width: 120px"
              />
              <h5>王五</h5>
              <p class="text-muted">市场总监</p>
            </div>
            <div class="col-md-3 team-member text-center">
              <img
                src="/static/dist/img/user4-128x128.jpg"
                alt="团队成员"
                class="img-fluid rounded-circle mb-3"
                style="max-width: 120px"
              />
              <h5>赵六</h5>
              <p class="text-muted">财务总监</p>
            </div>
          </div>
        </div>

        <!-- 公司荣誉 -->
        <div class="honors-section mt-5">
          <h3 class="text-center mb-4">公司荣誉</h3>
          <div class="row">
            <div class="col-md-3 text-center">
              <div class="honor-item">
                <i class="fas fa-trophy fa-2x text-warning mb-3"></i>
                <h6>行业领先</h6>
                <p class="small">业界口碑最佳</p>
              </div>
            </div>
            <div class="col-md-3 text-center">
              <div class="honor-item">
                <i class="fas fa-certificate fa-2x text-info mb-3"></i>
                <h6>资质认证</h6>
                <p class="small">通过多项认证</p>
              </div>
            </div>
            <div class="col-md-3 text-center">
              <div class="honor-item">
                <i class="fas fa-users fa-2x text-success mb-3"></i>
                <h6>用户信任</h6>
                <p class="small">数百万用户选择</p>
              </div>
            </div>
            <div class="col-md-3 text-center">
              <div class="honor-item">
                <i class="fas fa-star fa-2x text-danger mb-3"></i>
                <h6>持续创新</h6>
                <p class="small">不断追求进步</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
<style>
  .about-text {
    font-size: 16px;
    line-height: 1.8;
    color: #555;
    background: #f9f9f9;
    padding: 30px;
    border-radius: 8px;
    border-left: 4px solid #007bff;
  }
  .team-member {
    padding: 20px;
    transition: transform 0.3s ease;
  }
  .team-member:hover {
    transform: translateY(-5px);
  }
  .honor-item {
    padding: 20px;
    background: #f8f9fa;
    border-radius: 8px;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }
  .honor-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
  }
</style>
{{ end }}
