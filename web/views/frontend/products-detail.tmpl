{{define "content"}}
<div class="container">
  <div class="py-5">
    <!-- 返回按钮 -->
    <div class="mb-4">
      <a href="/products" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left"></i> 返回产品列表
      </a>
    </div>

    <!-- 产品详情 -->
    <div class="card">
      <div class="row g-0">
        <!-- 产品图片 -->
        <div class="col-md-5">
          <img
            src="{{.Product.ImgUrl}}"
            class="img-fluid rounded-start"
            alt="{{.Product.Name}}"
            style="height: 100%; object-fit: cover"
          />
        </div>

        <!-- 产品信息 -->
        <div class="col-md-7">
          <div class="card-body">
            <h2 class="card-title mb-4">{{.Product.Name}}</h2>
            <p class="card-text">{{.Product.Desc}}</p>

            <!-- 产品元信息 -->
            <div class="mt-4">
              <p class="text-muted"><strong>产品ID：</strong> {{.Product.ID}}</p>
              <p class="text-muted">
                <strong>创建时间：</strong> {{.Product.CreatedAt.Format "2006-01-02 15:04:05"}}
              </p>
              <p class="text-muted">
                <strong>更新时间：</strong> {{.Product.UpdatedAt.Format "2006-01-02 15:04:05"}}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 相关产品 -->
    {{if .RelatedProducts}}
    <div class="mt-5">
      <h3 class="section-title mb-4">相关产品</h3>
      <div class="row">
        {{ range.RelatedProducts }}
        <div class="col-lg-4 col-md-6 mb-4">
          <div class="card h-100">
            <img
              src="{{.ImgUrl}}"
              class="card-img-top"
              alt="{{.Name}}"
              style="height: 200px; object-fit: cover"
            />
            <div class="card-body">
              <h5 class="card-title">{{.Name}}</h5>
              <p class="card-text">{{.Desc}}</p>
              <a href="/products/{{.ID}}" class="btn btn-primary">查看详情</a>
            </div>
          </div>
        </div>
        {{ end }}
      </div>
    </div>
    {{ end }}
  </div>
</div>
{{ end }}
