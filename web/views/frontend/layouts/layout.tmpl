<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{if .Site.Title}}{{.Site.Title}}{{else}}企业门户网站{{ end }}</title>
    <!-- 引入AdminLTE CSS -->
    <link rel="stylesheet" href="/static/dist/css/adminlte.min.css" />
    <!-- 引入Font Awesome -->
    <link rel="stylesheet" href="/static/plugins/fontawesome-free/css/all.min.css" />
    <!-- 自定义样式 -->
    <style>
      .navbar {
        background-color: #ffffff;
        border-bottom: 1px solid #e9ecef;
      }
      .navbar-brand {
        color: #007bff !important;
        font-weight: bold;
      }
      .hero-section {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        overflow: hidden;
        color: #ffffff;
      }
      .hero-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        filter: brightness(0.6);
        z-index: 1;
      }
      .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        z-index: 2;
      }
      .hero-content {
        position: relative;
        z-index: 3;
        width: 100%;
        padding: 120px 0;
      }
      .hero-content h1,
      .hero-content p {
        color: #ffffff;
      }
      .section-title {
        text-align: center;
        margin-bottom: 50px;
        color: #343a40;
      }
      .card {
        border: none;
        box-shadow: 0 0 15px rgba(0, 0, 0, 0.05);
      }
      .news-item {
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease;
      }
      .news-item:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
      }
      .footer {
        background-color: #343a40;
        color: #ffffff;
        padding: 50px 0 10px 0;
        margin-top: 50px;
      }
      .footer a {
        color: #cfd8dc;
      }
      .footer a:hover {
        color: #ffffff;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <!-- 导航栏 -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white">
      <div class="container">
        <a class="navbar-brand" href="/">{{.Site.Title}}</a>
        <button
          class="navbar-toggler"
          type="button"
          data-toggle="collapse"
          data-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ml-auto">
            <li class="nav-item active">
              <a class="nav-link" href="/">首页 <span class="sr-only">(current)</span></a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/about">关于我们</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/products">产品中心</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/news">新闻动态</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/contact">联系我们</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- 页面内容 -->
    {{template "content" .}}

    <!-- 页脚 -->
    <footer class="footer">
      <div class="container">
        <div class="row">
          <div class="col-md-6">
            <h5>友情链接</h5>
            <ul class="list-unstyled">
              <li>
                <a href="{{.Site.FL1URL}}" class="text-white" target="_blank">{{.Site.FL1}}</a>
              </li>
              <li>
                <a href="{{.Site.FL2URL}}" class="text-white" target="_blank">{{.Site.FL2}}</a>
              </li>
              <li>
                <a href="{{.Site.FL3URL}}" class="text-white" target="_blank">{{.Site.FL3}}</a>
              </li>
              <li>
                <a href="{{.Site.FL4URL}}" class="text-white" target="_blank">{{.Site.FL4}}</a>
              </li>
              <li>
                <a href="{{.Site.FL5URL}}" class="text-white" target="_blank">{{.Site.FL5}}</a>
              </li>
            </ul>
          </div>
          <div class="col-md-6">
            <h5>联系我们</h5>
            <ul class="list-unstyled">
              <li><i class="fas fa-map-marker-alt"></i> 备案号：{{.Site.ICP}}</li>
              <li><i class="fas fa-phone"></i> 联系电话: {{.Site.Tel}}</li>
              <li>
                <i class="fas fa-envelope"></i>
                邮箱：{{.Site.Email}}
              </li>
            </ul>
          </div>
        </div>
        <hr class="bg-white" />
        <div class="text-center">
          <p>{{.Site.Copyright}}</p>
        </div>
      </div>
    </footer>

    <!-- 引入AdminLTE JS -->
    <script src="/static/plugins/jquery/jquery.min.js"></script>
    <script src="/static/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/static/dist/js/adminlte.min.js"></script>
  </body>
</html>
